  "agent": {
    "Atlas (Plan Executor)": {
      "model": "openai/gpt-5.4",
      "options": {
        "reasoningEffort": "high"
      },
      "steps": 999999
    },
    "Hephaestus (Deep Agent)": {
      "model": "openai/gpt-5.4",
      "options": {
        "reasoningEffort": "high"
      },
      "steps": 999999
    },
    "Metis (Plan Consultant)": {
      "model": "openai/gpt-5.4-mini",
      "options": {
        "reasoningEffort": "high"
      },
      "steps": 999999
    },
    "Momus (Plan Critic)": {
      "model": "openai/gpt-5.4-mini",
      "options": {
        "reasoningEffort": "high"
      },
      "steps": 999999
    },
    "Prometheus (Plan Builder)": {
