{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biometrics.dev/contracts/scorecard.schema.json",
  "title": "Scorecard",
  "type": "object",
  "required": [
    "run_id",
    "quality_score",
    "median_time_to_green_seconds",
    "cost_per_success",
    "critical_policy_violations",
    "success_rate",
    "timeouts",
    "dispatch_p95_ms",
    "fallback_rate",
    "backpressure_per_run",
    "objective",
    "composite_score",
    "thresholds",
    "generated_at"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "underlying_run_id": { "type": "string" },
    "dataset_id": { "type": "string" },
    "evidence_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "quality_delta",
          "time_to_green_improvement_percent",
          "cost_improvement_percent",
          "composite_delta"
        ],
        "properties": {
          "quality_delta": { "type": "number" },
          "time_to_green_improvement_percent": { "type": "number" },
          "cost_improvement_percent": { "type": "number" },
          "composite_delta": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "median_time_to_green_seconds": { "type": "number", "minimum": 0 },
    "cost_per_success": { "type": "number", "minimum": 0 },
    "critical_policy_violations": { "type": "integer", "minimum": 0 },
    "success_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "timeouts": { "type": "integer", "minimum": 0 },
    "dispatch_p95_ms": { "type": "number", "minimum": 0 },
    "fallback_rate": { "type": "number", "minimum": 0 },
    "backpressure_per_run": { "type": "number", "minimum": 0 },
    "objective": {
      "type": "object",
      "required": ["quality", "speed", "cost"],
      "properties": {
        "quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "speed": { "type": "number", "minimum": 0, "maximum": 1 },
        "cost": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "composite_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "thresholds": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
