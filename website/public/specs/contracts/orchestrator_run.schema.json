{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biometrics.dev/contracts/orchestrator_run.schema.json",
  "title": "OrchestratorRun",
  "type": "object",
  "required": [
    "id",
    "plan_id",
    "project_id",
    "goal",
    "strategy_mode",
    "policy_profile",
    "objective",
    "steps",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "underlying_run_id": { "type": "string" },
    "project_id": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "strategy_mode": {
      "type": "string",
      "enum": ["deterministic", "adaptive", "arena"]
    },
    "agent_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "allowed_tools": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "max_parallelism": { "type": "integer", "minimum": 1, "maximum": 32 },
          "model_policy": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "policy_profile": {
      "type": "object",
      "properties": {
        "exfiltration": { "type": "string" },
        "secrets": { "type": "string" },
        "filesystem": { "type": "string" },
        "network": { "type": "string" },
        "approvals": { "type": "string" }
      },
      "additionalProperties": false
    },
    "objective": {
      "type": "object",
      "required": ["quality", "speed", "cost"],
      "properties": {
        "quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "speed": { "type": "number", "minimum": 0, "maximum": 1 },
        "cost": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "error": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "current_step_id": { "type": "string" },
    "optimizer_recommendation_id": { "type": "string" },
    "optimizer_confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "paused", "cancelled", "completed", "failed"]
    },
    "error": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
